<refentry xml:id="yaf-view-interface.setscriptpath" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>Yaf_View_Interface::setScriptPath</refname>
  <refpurpose>Устанавливает базовый путь к каталогу с шаблонами представлений</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <modifier>abstract</modifier> <modifier>public</modifier> <type>void</type><methodname>Yaf_View_Interface::setScriptPath</methodname>
   <methodparam><type>string</type><parameter>template_dir</parameter></methodparam>
  </methodsynopsis>
  <para>
   Метод устанавливает базовый каталог шаблонов.
   В стандартном сценарии путь к шаблонам представлений указывают через диспетчер <classname>Yaf_Dispatcher</classname>.
  </para>

  &warn.undocumented.func;

 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>template_dir</parameter></term>
    <listitem>
     <para>
      Абсолютный путь к каталогу шаблонов.
      Диспетчер <classname>Yaf_Dispatcher</classname> передаёт в параметр путь к стандартному каталогу хранения шаблонов в корне приложения:
      <link linkend="configuration.yaf.directory">application.directory</link> . "/views".
     </para>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <para>

  </para>
 </refsect1>

</refentry>
