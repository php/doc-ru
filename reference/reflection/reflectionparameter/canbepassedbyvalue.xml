<refentry xml:id="reflectionparameter.canbepassedbyvalue" xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink">
 <refnamediv>
  <refname>ReflectionParameter::canBePassedByValue</refname>
  <refpurpose>Проверяет, по значению ли параметр принимает аргумент</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis role="ReflectionParameter">
   <modifier>public</modifier> <type>bool</type><methodname>ReflectionParameter::canBePassedByValue</methodname>
   <void/>
  </methodsynopsis>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  &no.function.parameters;
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Метод возвращает &true;, если параметр принимает аргумент по значению, иначе возвращается &false;.
  </simpara>
 </refsect1>

</refentry>
