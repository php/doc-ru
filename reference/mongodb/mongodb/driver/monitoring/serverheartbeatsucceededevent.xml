 <title>Класс MongoDB\Driver\Monitoring\ServerHeartbeatSucceededEvent</title>
 <titleabbrev>MongoDB\Driver\Monitoring\ServerHeartbeatSucceededEvent</titleabbrev>

 <partintro>

  <!-- {{{ MongoDB\Driver\Monitoring\ServerHeartbeatSucceededEvent intro -->
  <section xml:id="mongodb-driver-monitoring-serverheartbeatsucceededevent.intro">
   &reftitle.intro;
   <para>
    Класс <classname>MongoDB\Driver\Monitoring\ServerHeartbeatSucceededEvent</classname>
    инкапсулирует информацию об успешном heartbeat сервера — команде
    <link xlink:href="&url.mongodb.docs;reference/command/hello/">hello</link>,
    которую отправил
    <link xlink:href="&url.mongodb.sdam;">мониторинг сервера</link>.
   </para>
  </section>
  <!-- }}} -->

