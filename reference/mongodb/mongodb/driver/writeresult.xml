 <partintro>

<!-- {{{ MongoDB\Driver\WriteResult intro -->
  <section xml:id="mongodb-driver-writeresult.intro">
   &reftitle.intro;
   <para>
    Класс <classname>MongoDB\Driver\WriteResult</classname> инкапсулирует
    информацию о выполненном
    <classname>MongoDB\Driver\BulkWrite</classname> и может быть возвращён
    <methodname>MongoDB\Driver\Manager::executeBulkWrite</methodname>.
   </para>
  </section>
<!-- }}} -->

