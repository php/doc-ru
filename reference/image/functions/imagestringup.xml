<refentry xml:id="function.imagestringup" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>imagestringup</refname>
  <refpurpose>Рисует строку текста вертикально</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type>true</type><methodname>imagestringup</methodname>
   <methodparam><type>GdImage</type><parameter>image</parameter></methodparam>
   <methodparam><type class="union"><type>GdFont</type><type>int</type></type><parameter>font</parameter></methodparam>
   <methodparam><type>int</type><parameter>x</parameter></methodparam>
   <methodparam><type>int</type><parameter>y</parameter></methodparam>
   <methodparam><type>string</type><parameter>string</parameter></methodparam>
   <methodparam><type>int</type><parameter>color</parameter></methodparam>
  </methodsynopsis>
  <para>
   Функция рисует текст <parameter>string</parameter> вертикально по заданным координатам.
  </para>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    &gd.image.description;
    &gd.font.description;
    <varlistentry>
     <term><parameter>x</parameter></term>
     <listitem>
      <para>
       Координата нижнего левого угла по оси x.
      </para>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>y</parameter></term>
     <listitem>
      <para>
       Координата нижнего левого угла по оси y.
      </para>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>string</parameter></term>
     <listitem>
      <para>
       Текст надписи.
      </para>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>color</parameter></term>
     <listitem>
      <para>
       &gd.identifier.color;
      </para>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <para>
   &return.true.always;
  </para>
 </refsect1>

 <refsect1 role="changelog">
  &reftitle.changelog;
  <informaltable>
   <tgroup cols="2">
    <thead>
     <row>
      <entry>&Version;</entry>
      <entry>&Description;</entry>
     </row>
    </thead>
    <tbody>
     &gd.changelog.gdfont-instance;
     &gd.changelog.image-param;
    </tbody>
   </tgroup>
  </informaltable>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <para>
   <example>
    <title>Пример вертикальной отрисовки строки текста функцией <function>imagestringup</function></title>
    <programlisting role="php">
<![CDATA[
<?php

// Создаём изображение размером 100 на 100 пикселей
$im = imagecreatetruecolor(100, 100);

// Наносим надпись
$textcolor = imagecolorallocate($im, 0xFF, 0xFF, 0xFF);
imagestringup($im, 3, 40, 80, 'gd library', $textcolor);

// Сохраняем изображение
imagepng($im, './stringup.png');
]]>
    </programlisting>
    &example.outputs.similar;
    <mediaobject>
     <alt>Вывод примера: Изображение с отрисовкой текста по вертикали функцией imagestringup()</alt>
     <imageobject>
      <imagedata fileref="en/reference/image/figures/imagestringup.png"/>
     </imageobject>
    </mediaobject>
   </example>
  </para>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>imagestring</function></member>
   <member><function>imageloadfont</function></member>
  </simplelist>
 </refsect1>
</refentry>
