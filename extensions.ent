<!--
  Entities for the categorized extension list, so it does not need
  to be translated, and thus it is not going to be outdated.
-->

<!ENTITY extcat.intro '
<title xmlns="http://docbook.org/ns/docbook">Список модулей</title>
<simpara xmlns="http://docbook.org/ns/docbook">
 Приложение классифицирует более 150 задокументированных в PHP-руководстве модулей по алфавиту, способу распространения и другим критериям.
</simpara>
'>

<!ENTITY extcat.alphabetical '<title xmlns="http://docbook.org/ns/docbook">В алфавитном порядке</title>'>

<!-- ======================================================================= -->

<!ENTITY extcat.purpose '<title xmlns="http://docbook.org/ns/docbook">Цель</title>'>

