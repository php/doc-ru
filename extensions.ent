<!ENTITY extcat.purpose.basic.text '<title xmlns="http://docbook.org/ns/docbook">Обработка текста</title>'>
<!ENTITY extcat.purpose.basic.php '<title xmlns="http://docbook.org/ns/docbook">Изменение поведения PHP</title>'>
<!ENTITY extcat.purpose.basic.session '<title xmlns="http://docbook.org/ns/docbook">Модули для работы с сессиями</title>'>
<!ENTITY extcat.purpose.basic.other '<title xmlns="http://docbook.org/ns/docbook">Другие базовые модули</title>'>

<!ENTITY extcat.purpose.database '<title xmlns="http://docbook.org/ns/docbook">Модули для работы с базами данных</title>'>
<!ENTITY extcat.purpose.database.abstract '<title xmlns="http://docbook.org/ns/docbook">Уровни абстракции</title>'>
<!ENTITY extcat.purpose.database.vendors '<title xmlns="http://docbook.org/ns/docbook">Модули для работы с базами данных отдельных производителей</title>'>

<!ENTITY extcat.purpose.xml '<title xmlns="http://docbook.org/ns/docbook">Обработка XML</title>'>

<!ENTITY extcat.purpose.webservice '<title xmlns="http://docbook.org/ns/docbook">Веб-сервисы</title>'>

<!ENTITY extcat.purpose.creditcard '<title xmlns="http://docbook.org/ns/docbook">Обработка кредитных карт</title>'>

